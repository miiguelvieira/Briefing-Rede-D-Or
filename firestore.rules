rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return userDoc().role;
    }

    function isAdmin() {
      return isAuth() && role() == 'admin';
    }

    function isStaff() {
      return isAuth() && role() in ['admin', 'analyst'];
    }

    // ── Meta (seed flag) ──────────────────────────────────────────────────
    // Unauthenticated read allowed so the seed check can run before login.
    match /meta/{docId} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ── Config (admin-only — stores demo credentials hints, etc.) ─────────
    match /config/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read user profiles (needed for getUserName lookups)
      allow read: if isAuth();
      // Users can update their own profile; admins can update any
      allow create: if isAuth();
      allow update: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Tickets ───────────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      // Any authenticated user can read tickets (portal filters by userId client-side)
      allow read: if isAuth();
      // Any authenticated user can create a ticket (briefing submission)
      allow create: if isAuth();
      // Only staff (analysts + admin) can update tickets
      allow update: if isStaff();
      // Only admin can delete tickets
      allow delete: if isAdmin();

      // ── Comments subcollection ──────────────────────────────────────────
      match /comments/{commentId} {
        // Any authenticated user can read and create comments
        allow read:   if isAuth();
        allow create: if isAuth();
        // Nobody can update or delete comments (append-only log)
        allow update, delete: if false;
      }
    }
  }
}
